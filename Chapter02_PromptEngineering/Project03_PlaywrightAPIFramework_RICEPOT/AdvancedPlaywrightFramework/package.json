{
  "name": "advanced-playwright-api-framework",
  "version": "1.0.0",
  "description": "Enterprise-level Playwright API automation framework for restful-booker using APIRequestContext",
  "scripts": {
    "test": "playwright test",
    "test:auth": "playwright test tests/auth",
    "test:booking": "playwright test tests/booking",
    "test:ping": "playwright test tests/ping",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.11.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.4.0"
  }
}
